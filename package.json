{
  "name": "smart-todo-engine",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "env -u TURBOPACK NODE_ENV=production next build",
    "build:stats": "tsx scripts/generate-stats-page.ts",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import tsx/esm --test tests/engine.test.ts tests/statistics.test.ts tests/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm test && npm run typecheck && npm run lint && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
